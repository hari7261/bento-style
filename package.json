{
  "name": "bento-style",
  "version": "1.0.0",
  "description": "Production-ready Bento Grid React component library with Tailwind CSS",
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hari7261/bento-style.git"
  },
  "bugs": {
    "url": "https://github.com/hari7261/bento-style/issues"
  },
  "homepage": "https://github.com/hari7261/bento-style#readme",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run",
    "lint:package": "publint",
    "check": "npm run typecheck && npm run test && npm run build && npm run lint:package && npm run pack:check",
    "prepublishOnly": "npm run check"
  },
  "keywords": [
    "react",
    "bento",
    "grid",
    "component",
    "tailwind",
    "typescript",
    "ui"
  ],
  "author": "Hariom Kumar",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "tailwindcss": ">=3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.14",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.24",
    "publint": "^0.3.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^3.1.1"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.0.0"
  }
}
